# syzploit configuration
# Copy this file to .env and fill in your values.
# Keys are loaded automatically on startup — no need to export them.

# ── LLM API Keys (set at least one) ─────────────────────────────────
# syzploit checks these in order and uses the first one found.
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-v1-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# ── LLM Model ───────────────────────────────────────────────────────
# Any LiteLLM-compatible model identifier.
# SYZPLOIT_LLM_MODEL=openrouter/anthropic/claude-sonnet-4.6

# ── Infrastructure ───────────────────────────────────────────────────
# These are used as defaults by verify-exploit, the agent, and other
# commands.  CLI flags always override these values.
# SYZPLOIT_SSH_HOST=cuttlefish2
# SYZPLOIT_SSH_PORT=22
# SYZPLOIT_INSTANCE=5
# SYZPLOIT_START_CMD=cd /home/jack/challenge-4/challenge-4.1 && ./gdb_run.sh 5
# SYZPLOIT_STOP_CMD=cd /home/jack/challenge-4/challenge-4.1 && ./stop.sh 5
# SYZPLOIT_EXPLOIT_START_CMD=cd /home/jack/challenge-4/challenge-4.1 && ./run.sh 5
# SYZPLOIT_GDB_PORT=1234
# SYZPLOIT_ADB_PORT=6524
# SYZPLOIT_SETUP_TUNNELS=true
# SYZPLOIT_PERSISTENT=false
# SYZPLOIT_VMLINUX_PATH=/path/to/vmlinux

# ── Data directory ───────────────────────────────────────────────────
# SYZBOT_REPRO_DATA_DIR=/workspace/syzploit/syzploit_data/

# ── Debug ────────────────────────────────────────────────────────────
# SYZPLOIT_DEBUG=true
# SYZPLOIT_VERBOSE=true
